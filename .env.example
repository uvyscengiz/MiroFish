# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== 图谱后端配置 =====
GRAPH_BACKEND=graphiti

# ===== Neo4j / Graphiti 配置（GRAPH_BACKEND=graphiti 时必填）=====
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_this_password
NEO4J_DATABASE=neo4j

# ===== Graphiti LLM / Embedding 配置（可选）=====
# 如果你的 OpenAI 兼容端点不提供 embeddings，系统会自动退化到本地哈希向量。
GRAPHITI_LLM_MODEL=gpt-4.1
GRAPHITI_SMALL_LLM_MODEL=gpt-4.1-mini
GRAPHITI_EMBEDDING_MODEL=text-embedding-3-small

# ===== Flask 运行配置（可选）=====
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_DEBUG=true

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
